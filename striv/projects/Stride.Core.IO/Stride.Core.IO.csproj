<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../../build/StriV.Core.Profile.props" />
  <PropertyGroup>
    <AssemblyName>Stride.Core.IO</AssemblyName>
    <RootNamespace>Stride.Core.IO</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <StriVAssemblyProcessorOptions>--auto-module-initializer</StriVAssemblyProcessorOptions>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="../../..//sources/core/Stride.Core.IO/**/*.cs" Exclude="**/bin/**;**/obj/**" />
    <!-- Android expansion ZIP helper is mobile-only and excluded from the Linux desktop clean profile. -->
    <Compile Remove="../../../sources/core/Stride.Core.IO/System.IO.Compression.Zip/ApkExpansionSupport.cs" />
    <Compile Include="../../../sources/shared/SharedAssemblyInfo.cs">
      <Link>Properties/SharedAssemblyInfo.cs</Link>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Stride.Core/Stride.Core.csproj" />
  </ItemGroup>
  <Import Project="../../build/StriV.AssemblyProcessor.targets" />
</Project>
