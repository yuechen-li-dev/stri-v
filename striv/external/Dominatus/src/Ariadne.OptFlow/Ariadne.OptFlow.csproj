<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>Ariadne.OptFlow</PackageId>
    <Version>0.1.0</Version>
    <Authors>Dominatus Contributors</Authors>
    <Description>A dialogue-focused authoring layer for Dominatus, built on the same stateful runtime used for game and simulation agents.</Description>
    <PackageTags>dialogue;narrative;text-adventure;ai;hfsm;game-ai</PackageTags>
    <RepositoryUrl>https://github.com/yuechen-li-dev/Dominatus</RepositoryUrl>
    <PackageProjectUrl>https://github.com/yuechen-li-dev/Dominatus</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dominatus.Core\Dominatus.Core.csproj" />
    <ProjectReference Include="..\Dominatus.OptFlow\Dominatus.OptFlow.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Link="README.md" />
  </ItemGroup>

</Project>
