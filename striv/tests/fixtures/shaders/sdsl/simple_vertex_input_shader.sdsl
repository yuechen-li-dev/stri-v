shader SimpleVertexInputShader
{
    stage stream float3 Position : POSITION;
    stage stream float2 TexCoord : TEXCOORD0;
    stage stream float4 ClipPosition : SV_Position;

    stage override void VSMain()
    {
        streams.ClipPosition = float4(streams.Position, 1.0);
        streams.TexCoord = streams.TexCoord;
    }

    stage override float4 PSMain()
    {
        return float4(streams.TexCoord, 0.0, 1.0);
    }
}
